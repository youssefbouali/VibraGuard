{
  "spec": {
    "template": {
      "spec": {
        "volumes": [
          {
            "name": "provisioning-datasources",
            "configMap": {
              "name": "grafana-datasources"
            }
          }
        ],
        "containers": [
          {
            "name": "grafana",
            "volumeMounts": [
              {
                "name": "provisioning-datasources",
                "mountPath": "/etc/grafana/provisioning/datasources/"
              }
            ]
          }
        ]
      }
    }
  }
}
